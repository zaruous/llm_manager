{
  "id" : "builtin-bge-m3-embedding",
  "name" : "BGE-M3 Embedding Server",
  "description" : "BAAI/bge-m3 embedding model server (FastAPI)",
  "builtin" : true,
  "runtimeType" : "PYTHON",
  "repoUrl" : "https://github.com/zaruous/bgem3-pyserver",
  "installCommands" : [ "pip install fastapi \"uvicorn[standard]\" FlagEmbedding torch pydantic numpy \"huggingface_hub[hf_xet]\"" ],
  "startCommand" : "python server.py",
  "port" : 18080,
  "healthCheckPath" : "/health",
  "argSpecs" : [ {
    "name" : "port",
    "flag" : "--port",
    "type" : "INTEGER",
    "defaultValue" : "18080",
    "description" : "서버 포트",
    "enabled" : true
  }, {
    "name" : "device",
    "flag" : "--device",
    "type" : "SELECT",
    "defaultValue" : "auto",
    "description" : "연산 장치",
    "options" : [ "auto", "cpu", "cuda", "mps" ],
    "enabled" : true
  }, {
    "name" : "fp16",
    "flag" : "--fp16",
    "type" : "BOOLEAN",
    "defaultValue" : "false",
    "description" : "FP16 모드 (CUDA 권장)",
    "enabled" : true
  }, {
    "name" : "batch-size",
    "flag" : "--batch-size",
    "type" : "INTEGER",
    "defaultValue" : "32",
    "description" : "배치 크기",
    "enabled" : true
  }, {
    "name" : "model",
    "flag" : "--model",
    "type" : "STRING",
    "defaultValue" : "BAAI/bge-m3",
    "description" : "모델 이름",
    "enabled" : true
  } ],
  "argValues" : { },
  "envVars" : { }
}
