{
  "id" : "builtin-sql-gen-mcp",
  "name" : "SQL Gen MCP Server",
  "description" : "자연어를 SQL로 변환하는 MCP 서버. LangChain4j + PostgreSQL + TEI 임베딩 기반.",
  "builtin" : true,
  "runtimeType" : "JAVA",
  "startCommand" : "java -jar sql-gen-mcp-1.0.0-SNAPSHOT.jar",
  "installDir" : "${user.home}/llm-services/sql-gen-mcp",
  "port" : 7070,
  "healthCheckPath" : "/actuator/health",
  "installCommands" : [],
  "argSpecs" : [

    {
      "name" : "server.port",
      "flag" : "--server.port=",
      "type" : "INTEGER",
      "defaultValue" : "8081",
      "description" : "[MCP 서버] HTTP 리슨 포트",
      "enabled" : false
    },
    {
      "name" : "mcp.port",
      "flag" : "--mcp.port=",
      "type" : "INTEGER",
      "defaultValue" : "7070",
      "description" : "[MCP 서버] MCP 프로토콜 포트 — Claude Code 등 MCP 클라이언트가 연결하는 포트",
      "enabled" : true
    },

    {
      "name" : "db.url",
      "flag" : "--db.url=",
      "type" : "STRING",
      "defaultValue" : "jdbc:postgresql://192.168.45.7:5433/dbmes",
      "description" : "[DB] PostgreSQL 연결 URL",
      "enabled" : true
    },
    {
      "name" : "db.user",
      "flag" : "--db.user=",
      "type" : "STRING",
      "defaultValue" : "tester1",
      "description" : "[DB] 접속 사용자명",
      "enabled" : true
    },
    {
      "name" : "db.pw",
      "flag" : "--db.pw=",
      "type" : "STRING",
      "defaultValue" : "tester1",
      "description" : "[DB] 접속 비밀번호",
      "enabled" : true
    },
    {
      "name" : "db.schema",
      "flag" : "--db.schema=",
      "type" : "STRING",
      "defaultValue" : "public",
      "description" : "[DB] 사용할 스키마 이름 (기본값: public)",
      "enabled" : false
    },
    {
      "name" : "db.driver",
      "flag" : "--db.driver=",
      "type" : "STRING",
      "defaultValue" : "org.postgresql.Driver",
      "description" : "[DB] JDBC 드라이버 클래스명",
      "enabled" : false
    },

    {
      "name" : "tei.base-url",
      "flag" : "--ai.vector-store.providers.tei.base-url=",
      "type" : "STRING",
      "defaultValue" : "http://localhost:18080/v1",
      "description" : "[임베딩] TEI 서버 URL — /v1까지 포함. BGE-M3 등 임베딩 모델 주소.",
      "enabled" : true
    },

    {
      "name" : "embedding.provider",
      "flag" : "--ai.vector-store.embedding.provider=",
      "type" : "SELECT",
      "defaultValue" : "tei",
      "description" : "[임베딩] 모델 종류 — tei: Text Embeddings Inference (기본), local: ONNX 내장",
      "options" : [ "tei", "local", "ollama", "openai", "vllm" ],
      "enabled" : false
    },
    {
      "name" : "vector-store.provider",
      "flag" : "--ai.vector-store.provider=",
      "type" : "SELECT",
      "defaultValue" : "local",
      "description" : "[벡터 DB] 저장소 종류 — local: 인메모리(재시작 시 재인덱싱), chroma: ChromaDB 영속",
      "options" : [ "local", "chroma" ],
      "enabled" : false
    }

  ],
  "argValues" : {},
  "envVars" : {},
  "groovyScript" : "// installDir: JAR 파일이 있는 디렉토리 경로를 입력하세요.\n// 예) C:\\\\Users\\\\KYJ\\\\projects\\\\sql-gen-mcp\\\\bin\nservice.workingDir = service.installDir\nservice.startCommand = 'java -jar sql-gen-mcp-1.0.0-SNAPSHOT.jar'"
}
