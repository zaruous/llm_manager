{
  "id": "wiki-agent",
  "name": "LLM Wiki Agent",
  "version": "0.1.0",
  "type": "local",
  "permissions": [
    "filesystem.read",
    "filesystem.write",
    "process.exec",
    "network"
  ],
  "contributes": {
    "commands": [
      {
        "id": "wiki.ingest",
        "title": "문서 수집 (Ingest)",
        "description": "문서를 raw/에 수집하고 위키 페이지를 생성·갱신합니다. LLM 호출이 발생합니다.",
        "requires": {
          "cwd": true,
          "env": ["ANTHROPIC_API_KEY"]
        }
      },
      {
        "id": "wiki.query",
        "title": "위키 질의 (Query)",
        "description": "위키 전체를 조회해 질문에 답합니다. LLM 호출이 발생합니다.",
        "requires": {
          "cwd": true,
          "env": ["ANTHROPIC_API_KEY"]
        }
      },
      {
        "id": "wiki.health",
        "title": "구조 검사 (Health)",
        "description": "빈 페이지·인덱스 불일치·수집 로그 누락을 검사합니다. LLM 호출 없음.",
        "requires": {
          "cwd": true
        }
      },
      {
        "id": "wiki.lint",
        "title": "품질 검사 (Lint) — LLM 호출",
        "description": "모순·낡은 내용 등 의미론적 품질을 검사합니다. LLM 호출이 발생합니다.",
        "requires": {
          "cwd": true,
          "env": ["ANTHROPIC_API_KEY"]
        }
      },
      {
        "id": "wiki.graph",
        "title": "그래프 빌드 (Graph) — LLM 호출",
        "description": "위키링크와 AI 추론으로 지식 그래프(graph.html)를 생성합니다.",
        "requires": {
          "cwd": true,
          "env": ["ANTHROPIC_API_KEY"]
        }
      },
      {
        "id": "wiki.openGraph",
        "title": "그래프 열기 (브라우저)",
        "description": "빌드된 graph/graph.html을 OS 기본 브라우저로 엽니다.",
        "requires": {
          "cwd": true
        }
      },
      {
        "id": "wiki.browse",
        "title": "위키 브라우저",
        "description": "위키 페이지를 트리·마크다운 뷰로 탐색합니다. [[위키링크]] 이동 지원.",
        "requires": {
          "cwd": false
        }
      }
    ],
    "settingsTabs": [
      {
        "id": "wiki.settings",
        "title": "Wiki Agent",
        "order": 60,
        "type": "schema",
        "sections": [
          {
            "title": "Environment",
            "fields": [
              {
                "key": "ANTHROPIC_API_KEY",
                "label": "Anthropic API Key",
                "kind": "env",
                "required": true,
                "secret": true
              },
              {
                "key": "LLM_MODEL",
                "label": "LLM Model",
                "kind": "text",
                "defaultValue": "claude-sonnet-4-6"
              },
              {
                "key": "LLM_MODEL_FAST",
                "label": "LLM Model (Fast)",
                "kind": "text",
                "defaultValue": "claude-haiku-4-5"
              }
            ]
          },
          {
            "title": "Defaults",
            "fields": [
              {
                "key": "wiki.agent",
                "label": "실행 에이전트",
                "kind": "select",
                "defaultValue": "claude",
                "options": ["claude", "cursor"]
              },
              {
                "key": "wiki.defaultCwd",
                "label": "기본 워크스페이스",
                "kind": "directory",
                "defaultValue": ""
              },
              {
                "key": "timeoutMinutes",
                "label": "실행 타임아웃 (분, 비우면 무제한)",
                "kind": "string",
                "defaultValue": ""
              }
            ]
          }
        ]
      }
    ]
  }
}
